{
  "name": "krossing-ts-utils",
  "version": "0.0.5",
  "description": "This package consists of various utility or helper functions to enable easy development in Typescript.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./http-status-codes": {
      "types": "./dist/lib/http/status-codes.http.lib.d.ts",
      "import": "./dist/lib/http/status-codes.http.lib.js",
      "require": "./dist/lib/http/status-codes.http.lib.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsc && nodemon text.ts",
    "build": "tsc"
  },
  "author": "Krossing Technology",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
