{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2020",

    "declaration": true,
    "sourceMap": true,
    "declarationMap": false,

    "strict": true,
    "skipLibCheck": true,

    "isolatedModules": true,
    "verbatimModuleSyntax": false
  },
  "include": ["src"]
}